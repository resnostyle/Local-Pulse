# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=localpulse
MYSQL_PASSWORD=localpulse
MYSQL_DATABASE=localpulse

# OpenAI (for event normalization of html sources)
OPENAI_API_KEY=

# Celery (defaults work for local dev with docker compose)
# Container deployments override these with service hostnames.
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
